# =============================================================================
# ClusterGate - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before starting.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://clustergate:changeme@localhost:5432/clustergate?schema=public"
POSTGRES_USER=clustergate
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clustergate

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# REQUIRED: Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://clustergate.example.com

# Proxy settings
PROXY_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Metrics
METRICS_ENABLED=true
METRICS_SECRET=CHANGE_ME_METRICS_SECRET

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Cleanup
LOG_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=ClusterGate
NEXT_PUBLIC_APP_VERSION=1.0.0
