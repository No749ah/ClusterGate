// =============================================================================
// ClusterGate - Prisma Schema
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

enum RouteStatus {
  DRAFT
  PUBLISHED
}

enum AuthType {
  NONE
  API_KEY
  BASIC
  BEARER
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  UNKNOWN
}

enum LBStrategy {
  ROUND_ROBIN
  WEIGHTED
  FAILOVER
}

enum TransformPhase {
  REQUEST
  RESPONSE
}

enum TransformType {
  SET_HEADER
  REMOVE_HEADER
  REWRITE_BODY_JSON
  SET_QUERY_PARAM
  REMOVE_QUERY_PARAM
  MAP_STATUS_CODE
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum IncidentStatus {
  ACTIVE
  INVESTIGATING
  RESOLVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

// =============================================================================
// Models
// =============================================================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  role             Role      @default(VIEWER)
  isActive         Boolean   @default(true)
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  recoveryCodes    String[]  @default([])
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  createdRoutes    Route[]          @relation("RouteCreatedBy")
  updatedRoutes    Route[]          @relation("RouteUpdatedBy")
  routeVersions    RouteVersion[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  inviteTokens     InviteToken[]    @relation("InviteCreatedBy")
  orgMemberships   OrgMembership[]
  teamMemberships  TeamMembership[]
  changeRequestsMade    ChangeRequest[] @relation("ChangeRequestedBy")
  changeRequestsReviewed ChangeRequest[] @relation("ChangeReviewedBy")
  achievements     Achievement[]

  @@index([email])
  @@map("users")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  changeRequestsEnabled Boolean @default(false)

  teams       Team[]
  memberships OrgMembership[]
  routes      Route[]

  @@map("organizations")
}

model OrgMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("org_memberships")
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members     TeamMembership[]
  routeGroups RouteGroup[]

  @@unique([organizationId, name])
  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_memberships")
}

model RouteGroup {
  id          String  @id @default(cuid())
  name        String
  description String?
  pathPrefix  String  @unique // e.g. "/r/payments"

  // Inherited defaults
  defaultTimeout           Int?
  defaultRetryCount        Int?
  defaultRateLimitEnabled  Boolean?
  defaultRateLimitMax      Int?
  defaultRateLimitWindow   Int?
  defaultAuthType          AuthType?
  defaultAuthValue         String?
  defaultAddHeaders        Json?       // Record<string,string>
  defaultRemoveHeaders     String[]    @default([])
  defaultCorsEnabled       Boolean?
  defaultCorsOrigins       String[]    @default([])
  defaultIpAllowlist       String[]    @default([])

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Team scoping
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  routes      Route[]

  @@map("route_groups")
}

model Route {
  id           String      @id @default(cuid())
  name         String
  description  String?
  publicPath   String
  targetUrl    String
  methods      String[]    @default(["GET", "POST"])
  isActive     Boolean     @default(false)
  status       RouteStatus @default(DRAFT)
  tags         String[]    @default([])
  version      Int         @default(1)

  // Proxy settings
  timeout      Int         @default(30000)   // ms
  retryCount   Int         @default(0)
  retryDelay   Int         @default(1000)    // ms

  // Rate limiting
  rateLimitEnabled Boolean  @default(false)
  rateLimitMax     Int      @default(100)
  rateLimitWindow  Int      @default(60000)

  stripPrefix  Boolean     @default(false)
  sslVerify    Boolean     @default(true)
  requestBodyLimit String  @default("10mb")

  // Header rules
  addHeaders    Json        @default("{}")
  removeHeaders String[]    @default([])

  // Path rewrite
  rewriteRules  Json        @default("[]")

  // CORS
  corsEnabled  Boolean      @default(false)
  corsOrigins  String[]     @default([])

  // Security
  ipAllowlist  String[]     @default([])
  requireAuth  Boolean      @default(false)
  authType     AuthType     @default(NONE)
  authValue    String?
  webhookSecret String?

  // Maintenance
  maintenanceMode    Boolean @default(false)
  maintenanceMessage String? @default("This service is temporarily unavailable.")

  // WebSocket support
  wsEnabled    Boolean     @default(false)

  // Circuit breaker
  circuitBreakerEnabled Boolean   @default(false)
  cbFailureThreshold    Int       @default(5)
  cbRecoveryTimeout     Int       @default(30000)  // ms
  cbState               String    @default("CLOSED") // CLOSED | OPEN | HALF_OPEN
  cbFailureCount        Int       @default(0)
  cbLastFailureAt       DateTime?
  cbOpenedAt            DateTime?

  // Load balancing
  lbStrategy   LBStrategy  @default(ROUND_ROBIN)

  // Soft delete
  deletedAt    DateTime?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  createdById  String?
  createdBy    User?        @relation("RouteCreatedBy", fields: [createdById], references: [id])
  updatedById  String?
  updatedBy    User?        @relation("RouteUpdatedBy", fields: [updatedById], references: [id])

  routeGroupId String?
  routeGroup   RouteGroup?  @relation(fields: [routeGroupId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  versions       RouteVersion[]
  requestLogs    RequestLog[]
  apiKeys        ApiKey[]
  healthChecks   HealthCheck[]
  notifications  Notification[]
  targets        RouteTarget[]
  transformRules TransformRule[]
  incidents      Incident[]
  changeRequests ChangeRequest[]

  @@unique([publicPath])
  @@index([status, isActive])
  @@index([deletedAt])
  @@index([routeGroupId])
  @@index([organizationId])
  @@map("routes")
}

model RouteTarget {
  id        String   @id @default(cuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  url       String
  weight    Int      @default(100)   // 1-100 for WEIGHTED
  priority  Int      @default(0)     // lower = higher priority for FAILOVER
  isHealthy Boolean  @default(true)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routeId])
  @@map("route_targets")
}

model TransformRule {
  id        String         @id @default(cuid())
  routeId   String
  route     Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)
  phase     TransformPhase
  type      TransformType
  name      String
  config    Json           // type-specific config
  order     Int            @default(0)
  isActive  Boolean        @default(true)
  condition Json?          // optional condition
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([routeId, phase, order])
  @@map("transform_rules")
}

model RouteVersion {
  id        String   @id @default(cuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  createdById String?
  createdBy User?    @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())

  @@index([routeId, version])
  @@map("route_versions")
}

model RequestLog {
  id              String   @id @default(cuid())
  routeId         String?
  route           Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  requestId       String   @default(cuid())
  method          String
  path            String
  queryParams     Json     @default("{}")
  requestHeaders  Json     @default("{}")
  requestBody     String?
  responseStatus  Int?
  responseHeaders Json     @default("{}")
  responseBody    String?
  duration        Int?     // ms
  targetUrl       String
  error           String?
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([routeId, createdAt, duration])
  @@index([createdAt])
  @@index([createdAt, responseStatus])
  @@index([routeId, createdAt, responseStatus])
  @@map("request_logs")
}

model ApiKey {
  id         String    @id @default(cuid())
  routeId    String
  route      Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([routeId])
  @@index([keyHash])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?
  details    Json     @default("{}")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model HealthCheck {
  id            String       @id @default(cuid())
  routeId       String
  route         Route        @relation(fields: [routeId], references: [id], onDelete: Cascade)
  status        HealthStatus @default(UNKNOWN)
  lastCheckedAt DateTime     @default(now())
  responseTime  Int?         // ms
  error         String?
  createdAt     DateTime     @default(now())

  @@index([routeId, createdAt])
  @@map("health_checks")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// Incident Timeline
// =============================================================================

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      IncidentStatus   @default(ACTIVE)
  severity    IncidentSeverity @default(MEDIUM)
  routeId     String?
  route       Route?           @relation(fields: [routeId], references: [id], onDelete: SetNull)
  startedAt   DateTime         @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  events      IncidentEvent[]

  @@index([status])
  @@index([routeId])
  @@index([startedAt])
  @@map("incidents")
}

model IncidentEvent {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type        String   // health_check_failed, error_spike, cb_opened, cb_closed, manual_note, status_change, config_change
  title       String
  description String?
  metadata    Json     @default("{}")
  createdById String?
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
  @@map("incident_events")
}

// =============================================================================
// Change Requests (Approval Workflow)
// =============================================================================

model ChangeRequest {
  id          String              @id @default(cuid())
  routeId     String?
  route       Route?              @relation(fields: [routeId], references: [id], onDelete: SetNull)
  type        String              // create, update, delete
  status      ChangeRequestStatus @default(PENDING)
  title       String
  description String?
  payload     Json                // The proposed route config
  diff        Json?               // Computed diff for display

  requestedById String
  requestedBy   User   @relation("ChangeRequestedBy", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?  @relation("ChangeReviewedBy", fields: [reviewedById], references: [id])
  reviewComment String?
  reviewedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([routeId])
  @@index([requestedById])
  @@map("change_requests")
}

// =============================================================================
// Achievement System
// =============================================================================

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String   // e.g., first_route, century, million_requests
  unlockedAt  DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
  @@map("achievements")
}

model InviteToken {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(VIEWER)
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([email])
  @@map("invite_tokens")
}
